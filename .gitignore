## User AI spaces (these are user-specific, not part of the system)
# System bundle .ai/ dirs are INCLUDED
# Project .ai/knowledge/ is INCLUDED (project documentation)
/.ai/*
!.ai/knowledge/
*/.ai/
!bundles/.ai/
!bundles/.ai/**
!bundles/*/.ai/

## Allow lib/ directories inside .ai/ (not Python build artifacts)
!**/.ai/**/lib/

