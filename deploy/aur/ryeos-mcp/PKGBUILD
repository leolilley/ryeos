# Maintainer: Leo Lilley <leo.lml.lilley@gmail.com>
pkgname=ryeos-mcp
# Release template. scripts/release/prepare-aur.sh replaces both placeholders
# only after verifying the signed tag and hashing the exact source archive.
pkgver=RELEASE_VERSION
pkgrel=1
pkgdesc="MCP server wrapper for ryeos — stdio bridge to the ryeos CLI"
arch=('any')
url="https://github.com/leolilley/ryeos"
license=('MIT')

depends=('python>=3.10' 'python-mcp' 'ryeos')
makedepends=('python-build' 'python-installer' 'python-hatchling')

source=("$pkgname-$pkgver.tar.gz::https://github.com/leolilley/ryeos/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('RELEASE_ARCHIVE_SHA256')

build() {
    cd "ryeos-${pkgver}/integrations/mcp/ryeosd"
    python -m build --wheel --no-isolation
}

package() {
    cd "ryeos-${pkgver}/integrations/mcp/ryeosd"
    python -m installer --destdir="$pkgdir" dist/*.whl
    install -Dm644 ../LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
