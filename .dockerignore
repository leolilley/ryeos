# Virtual environments
.venv/
venv/
*.venv/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# IDE
.idea/
.vscode/
*.swp
*.swo

# Git
.git/
.gitignore

# Test and coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Build artifacts
*.egg-info/
dist/
build/
*.egg

# Ruff/linting
.ruff_cache/

# Heavy deps (not needed in Docker)
node_modules/
target/

# Local-machine cargo config has an absolute target-dir that breaks the
# container build (cargo writes binaries to the host path instead of /build).
# CI/Docker uses cargo's default target dir under the workspace.
.cargo/

# Local development
*.env
!.env.example
